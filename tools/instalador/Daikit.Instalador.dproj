<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <ProjectGuid>{42A79C4E-2FB3-4FA9-97CA-D94718DB2A25}</ProjectGuid>
    <ProjectVersion>20.0</ProjectVersion>
    <FrameworkType>VCL</FrameworkType>
    <MainSource>Daikit.Instalador.dpr</MainSource>
    <Base>true</Base>
    <Config Condition="'$(Config)'==''">Release</Config>
    <Platform Condition="'$(Platform)'==''">Win32</Platform>
    <TargetedPlatforms>1</TargetedPlatforms>
    <AppType>Application</AppType>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Config)'=='Base' or '$(Base)'!=''">
    <Base>true</Base>
    <DCC_Namespace>System;Xml;Data;Datasnap;Web;Soap;Vcl;Winapi;$(DCC_Namespace)</DCC_Namespace>
    <DCC_DcuOutput>bin\Win32\dcu</DCC_DcuOutput>
    <DCC_ExeOutput>bin\Win32</DCC_ExeOutput>
    <DCC_ForceExecute>false</DCC_ForceExecute>
    <SanitizedProjectName>DaikitInstalador</SanitizedProjectName>
    <DCC_DependencyCheckOutputName>bin\Win32\Daikit.Instalador.exe</DCC_DependencyCheckOutputName>
  </PropertyGroup>
  <PropertyGroup Condition="('$(Platform)'=='Win32' and '$(Base)'=='true') or '$(Base_Win32)'!=''">
    <Base_Win32>true</Base_Win32>
    <CfgParent>Base</CfgParent>
    <Base>true</Base>
    <DCC_DCCCompiler>DCC32</DCC_DCCCompiler>
    <DCC_Platform>x86</DCC_Platform>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Config)'=='Debug' or '$(Cfg_Debug)'!=''">
    <Cfg_Debug>true</Cfg_Debug>
    <CfgParent>Base</CfgParent>
    <Base>true</Base>
    <DCC_LocalDebugSymbols>true</DCC_LocalDebugSymbols>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Config)'=='Release' or '$(Cfg_Release)'!=''">
    <Cfg_Release>true</Cfg_Release>
    <CfgParent>Base</CfgParent>
    <Base>true</Base>
    <DCC_Optimization>true</DCC_Optimization>
  </PropertyGroup>
  <ItemGroup>
    <DelphiCompile Include="$(MainSource)"><MainSource>MainSource</MainSource></DelphiCompile>
    <DCCReference Include="Daikit.Instalador.Principal.pas"><Form>FormInstalador</Form><FormType>dfm</FormType></DCCReference>
    <DCCReference Include="Daikit.Instalador.Servico.pas"/>
    <BuildConfiguration Include="Base"><Key>Base</Key></BuildConfiguration>
    <BuildConfiguration Include="Debug"><Key>Cfg_Debug</Key><CfgParent>Base</CfgParent></BuildConfiguration>
    <BuildConfiguration Include="Release"><Key>Cfg_Release</Key><CfgParent>Base</CfgParent></BuildConfiguration>
  </ItemGroup>
  <ProjectExtensions>
    <Borland.Personality>Delphi.Personality.12</Borland.Personality>
    <Borland.ProjectType>VCLApplication</Borland.ProjectType>
    <BorlandProject><Delphi.Personality><Source><Source Name="MainSource">Daikit.Instalador.dpr</Source></Source></Delphi.Personality><Platforms><Platform value="Win32">True</Platform></Platforms></BorlandProject>
    <ProjectFileVersion>12</ProjectFileVersion>
  </ProjectExtensions>
  <Import Project="$(BDS)\Bin\CodeGear.Delphi.Targets" Condition="Exists('$(BDS)\Bin\CodeGear.Delphi.Targets')"/>
</Project>
